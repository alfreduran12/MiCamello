# ─── Base de datos ────────────────────────────────────────────
# Ruta ABSOLUTA al archivo SQLite en el servidor.
# Crea el directorio primero: mkdir -p /var/data/minotion
DATABASE_URL=file:/var/data/minotion/data.db

# ─── NextAuth ─────────────────────────────────────────────────
# URL pública de la app (sin trailing slash)
NEXTAUTH_URL=https://tudominio.com

# Secreto fuerte — genera con: openssl rand -base64 32
NEXTAUTH_SECRET=CAMBIA_ESTO

# ─── Puerto (opcional) ────────────────────────────────────────
# PORT=3001
